---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Lost on the Road">
  <div class="hero">
    <h1>🛣️ 404</h1>
    <p class="tagline">
      You took a road that doesn't exist yet.
      That's okay — every road starts somewhere.
    </p>
    <div class="nav-links">
      <a class="cta" href="/">Go Home</a>
      <a class="cta cta-outline" href="/roadmap">See the Roadmap</a>
      <a class="cta cta-outline" href="/playground">Try the Playground</a>
    </div>
  </div>

  <div class="container">
    <section class="section" style="text-align: center;">
      <div class="math">
        K(t) = C(t) · e^(λ|δ|)
      </div>
      <p>
        The unexpected just arrived — that's δ.
        And the system doesn't minimize it. It grows from it.
      </p>
      <p style="color: var(--white); margin-top: 2rem;">
        You showed up. You belong here. Let's find your road. 🛣️
      </p>
    </section>
  </div>
</Base>
