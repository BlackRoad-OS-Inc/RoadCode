---
import Base from "../layouts/Base.astro";
---

<Base title="GreenLight Playground — Build Emoji Strings" description="Interactive GreenLight builder. Click emojis to compose entity strings and see them parsed in real time.">
  <div class="hero">
    <h1>🎮 Playground</h1>
    <p class="tagline">
      Click emojis. Build entities. See them parsed live.
    </p>
  </div>

  <div class="container">
    <section class="section">
      <div class="builder">
        <div class="builder-display">
          <div class="builder-output" id="output">
            <span class="placeholder">Click emojis below to start building...</span>
          </div>
          <div class="builder-actions">
            <button class="btn btn-clear" id="clear-btn">Clear</button>
            <button class="btn btn-copy" id="copy-btn">Copy</button>
          </div>
        </div>

        <div class="parsed-output" id="parsed">
          <div class="parsed-empty">Your parsed entity will appear here</div>
        </div>
      </div>
    </section>

    <section class="section" id="picker">
      <div class="picker-category">
        <h3>Lifecycle</h3>
        <div class="picker-grid">
          <button class="emoji-btn" data-category="lifecycle" data-code="void" data-emoji="⬛">⬛<span>void</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="inbox" data-emoji="📥">📥<span>inbox</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="queued" data-emoji="📋">📋<span>queued</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="targeted" data-emoji="🎯">🎯<span>targeted</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="wip" data-emoji="🚧">🚧<span>wip</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="active" data-emoji="⚡">⚡<span>active</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="review" data-emoji="🔄">🔄<span>review</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="paused" data-emoji="⏸️">⏸️<span>paused</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="blocked" data-emoji="🔒">🔒<span>blocked</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="branched" data-emoji="🔀">🔀<span>branched</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="healing" data-emoji="🩹">🩹<span>healing</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="done" data-emoji="✅">✅<span>done</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="archived" data-emoji="📦">📦<span>archived</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="canceled" data-emoji="❌">❌<span>canceled</span></button>
          <button class="emoji-btn" data-category="lifecycle" data-code="dead" data-emoji="💀">💀<span>dead</span></button>
        </div>
      </div>

      <div class="picker-category">
        <h3>Scale</h3>
        <div class="picker-grid">
          <button class="emoji-btn" data-category="scale" data-code="micro" data-emoji="👉">👉<span>micro</span></button>
          <button class="emoji-btn" data-category="scale" data-code="macro" data-emoji="🎢">🎢<span>macro</span></button>
          <button class="emoji-btn" data-category="scale" data-code="planetary" data-emoji="🌐">🌐<span>planetary</span></button>
          <button class="emoji-btn" data-category="scale" data-code="universal" data-emoji="🌌">🌌<span>universal</span></button>
        </div>
      </div>

      <div class="picker-category">
        <h3>Domain</h3>
        <div class="picker-grid">
          <button class="emoji-btn" data-category="domain" data-code="platform" data-emoji="🛣️">🛣️<span>platform</span></button>
          <button class="emoji-btn" data-category="domain" data-code="ai" data-emoji="🌀">🌀<span>ai</span></button>
          <button class="emoji-btn" data-category="domain" data-code="chain" data-emoji="⛓️">⛓️<span>chain</span></button>
          <button class="emoji-btn" data-category="domain" data-code="coin" data-emoji="💎">💎<span>coin</span></button>
          <button class="emoji-btn" data-category="domain" data-code="intel" data-emoji="🧠">🧠<span>intel</span></button>
          <button class="emoji-btn" data-category="domain" data-code="media" data-emoji="📺">📺<span>media</span></button>
          <button class="emoji-btn" data-category="domain" data-code="audio" data-emoji="🎵">🎵<span>audio</span></button>
          <button class="emoji-btn" data-category="domain" data-code="games" data-emoji="🎮">🎮<span>games</span></button>
          <button class="emoji-btn" data-category="domain" data-code="edu" data-emoji="📚">📚<span>edu</span></button>
          <button class="emoji-btn" data-category="domain" data-code="security" data-emoji="🔒">🔒<span>security</span></button>
          <button class="emoji-btn" data-category="domain" data-code="gov" data-emoji="🏛️">🏛️<span>gov</span></button>
          <button class="emoji-btn" data-category="domain" data-code="biz" data-emoji="💼">💼<span>biz</span></button>
          <button class="emoji-btn" data-category="domain" data-code="infra" data-emoji="🔧">🔧<span>infra</span></button>
          <button class="emoji-btn" data-category="domain" data-code="creative" data-emoji="🎨">🎨<span>creative</span></button>
          <button class="emoji-btn" data-category="domain" data-code="data" data-emoji="📊">📊<span>data</span></button>
          <button class="emoji-btn" data-category="domain" data-code="growth" data-emoji="🌱">🌱<span>growth</span></button>
          <button class="emoji-btn" data-category="domain" data-code="partner" data-emoji="🤝">🤝<span>partner</span></button>
          <button class="emoji-btn" data-category="domain" data-code="labs" data-emoji="🔬">🔬<span>labs</span></button>
        </div>
      </div>

      <div class="picker-category">
        <h3>Priority</h3>
        <div class="picker-grid">
          <button class="emoji-btn" data-category="priority" data-code="p0" data-emoji="🔥">🔥<span>p0 fire</span></button>
          <button class="emoji-btn" data-category="priority" data-code="p1" data-emoji="🚨">🚨<span>p1 urgent</span></button>
          <button class="emoji-btn" data-category="priority" data-code="p2" data-emoji="⭐">⭐<span>p2 high</span></button>
          <button class="emoji-btn" data-category="priority" data-code="p3" data-emoji="📌">📌<span>p3 medium</span></button>
          <button class="emoji-btn" data-category="priority" data-code="p4" data-emoji="💤">💤<span>p4 low</span></button>
          <button class="emoji-btn" data-category="priority" data-code="p5" data-emoji="🧊">🧊<span>p5 ice</span></button>
        </div>
      </div>

      <div class="picker-category">
        <h3>Ownership</h3>
        <div class="picker-grid">
          <button class="emoji-btn" data-category="owner" data-code="human" data-emoji="👤">👤<span>human</span></button>
          <button class="emoji-btn" data-category="owner" data-code="agent" data-emoji="🤖">🤖<span>agent</span></button>
          <button class="emoji-btn" data-category="owner" data-code="system" data-emoji="⚙️">⚙️<span>system</span></button>
          <button class="emoji-btn" data-category="owner" data-code="team" data-emoji="👥">👥<span>team</span></button>
          <button class="emoji-btn" data-category="owner" data-code="hybrid" data-emoji="🎭">🎭<span>hybrid</span></button>
          <button class="emoji-btn" data-category="owner" data-code="none" data-emoji="❓">❓<span>none</span></button>
        </div>
      </div>

      <div class="picker-category">
        <h3>Agent</h3>
        <div class="picker-grid">
          <button class="emoji-btn" data-category="agent" data-code="cece" data-emoji="🌸">🌸<span>cece</span></button>
          <button class="emoji-btn" data-category="agent" data-code="lucidia" data-emoji="🔮">🔮<span>lucidia</span></button>
          <button class="emoji-btn" data-category="agent" data-code="alice" data-emoji="🐇">🐇<span>alice</span></button>
          <button class="emoji-btn" data-category="agent" data-code="silas" data-emoji="🎸">🎸<span>silas</span></button>
          <button class="emoji-btn" data-category="agent" data-code="aria" data-emoji="🌙">🌙<span>aria</span></button>
          <button class="emoji-btn" data-category="agent" data-code="blackroad" data-emoji="🎩">🎩<span>blackroad</span></button>
          <button class="emoji-btn" data-category="agent" data-code="edge" data-emoji="🦊">🦊<span>edge</span></button>
          <button class="emoji-btn" data-category="agent" data-code="swarm" data-emoji="🐙">🐙<span>swarm</span></button>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>NATS Subject</h2>
      <div class="nats-output" id="nats-output">
        <span class="placeholder">{"greenlight.{state}.{scale}.{domain}.{id}"}</span>
      </div>
    </section>

    <section class="section">
      <h2>Try These</h2>
      <div class="examples-list">
        <button class="example-preset" data-emojis="🚧👉🌀⭐🤖🌸">🚧👉🌀⭐🤖🌸 <span>WIP micro AI task, high, Cece</span></button>
        <button class="example-preset" data-emojis="✅🎢⛓️📌👥">✅🎢⛓️📌👥 <span>Done macro chain, medium, team</span></button>
        <button class="example-preset" data-emojis="🔒🌐🔧🔥⚙️">🔒🌐🔧🔥⚙️ <span>Blocked planetary infra, fire, system</span></button>
        <button class="example-preset" data-emojis="📥👉🎨💤👤">📥👉🎨💤👤 <span>Inbox micro creative, low, human</span></button>
        <button class="example-preset" data-emojis="🔀🎢🧠🚨🎭🔮">🔀🎢🧠🚨🎭🔮 <span>Branched macro intel, urgent, hybrid, Lucidia</span></button>
      </div>
    </section>
  </div>
</Base>

<style>
  .builder {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .builder-display {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #111;
    border: 2px solid var(--green);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    min-height: 4rem;
  }

  .builder-output {
    flex: 1;
    font-size: 2rem;
    letter-spacing: 0.1em;
    font-family: var(--font-mono);
    overflow-x: auto;
    white-space: nowrap;
  }

  .builder-output .placeholder {
    font-size: 1rem;
    color: var(--gray);
    letter-spacing: normal;
  }

  .builder-actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    border: 1px solid #333;
    cursor: pointer;
    transition: all 0.2s;
    background: transparent;
    color: var(--gray);
  }

  .btn:hover {
    border-color: var(--green);
    color: var(--white);
  }

  .btn-copy.copied {
    border-color: var(--green);
    color: var(--green);
  }

  .parsed-output {
    background: #111;
    border: 1px solid #222;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
    min-height: 3rem;
  }

  .parsed-empty {
    color: var(--gray);
    font-size: 0.85rem;
  }

  .parsed-row {
    display: flex;
    gap: 0.75rem;
  }

  .parsed-key {
    color: var(--green-dim);
    min-width: 6rem;
  }

  .parsed-value {
    color: var(--white);
  }

  .picker-category {
    margin-bottom: 2rem;
  }

  .picker-category h3 {
    margin-bottom: 0.75rem;
    font-size: 1rem;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
  }

  .picker-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .emoji-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    background: #111;
    border: 1px solid #222;
    border-radius: 10px;
    padding: 0.75rem 0.6rem 0.5rem;
    min-width: 4.5rem;
    cursor: pointer;
    transition: all 0.15s;
    font-size: 1.5rem;
  }

  .emoji-btn span {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--gray);
  }

  .emoji-btn:hover {
    border-color: var(--green);
    background: rgba(0, 230, 118, 0.05);
    transform: translateY(-2px);
  }

  .emoji-btn:active {
    transform: translateY(0);
  }

  .emoji-btn.selected {
    border-color: var(--green);
    background: rgba(0, 230, 118, 0.1);
    box-shadow: 0 0 12px rgba(0, 230, 118, 0.15);
  }

  .nats-output {
    background: #111;
    border-left: 3px solid var(--green);
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 1rem;
  }

  .nats-output .placeholder {
    color: var(--gray);
  }

  .examples-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .example-preset {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #111;
    border: 1px solid #222;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 1.2rem;
    text-align: left;
    color: var(--white);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  .example-preset span {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--gray);
    letter-spacing: normal;
  }

  .example-preset:hover {
    border-color: var(--green);
    background: rgba(0, 230, 118, 0.03);
  }

  @media (max-width: 600px) {
    .builder-display { flex-direction: column; align-items: stretch; }
    .builder-output { font-size: 1.5rem; }
    .emoji-btn { min-width: 3.5rem; padding: 0.5rem 0.4rem 0.35rem; font-size: 1.2rem; }
  }
</style>

<script>
  const emojiLookup: Record<string, { category: string; code: string }> = {};
  document.querySelectorAll('.emoji-btn').forEach(btn => {
    const el = btn as HTMLElement;
    const emoji = el.dataset.emoji!;
    const category = el.dataset.category!;
    const code = el.dataset.code!;
    emojiLookup[emoji] = { category, code };
  });

  const builder: { emojis: { emoji: string; category: string; code: string }[] } = { emojis: [] };

  function render() {
    const output = document.getElementById('output')!;
    const parsed = document.getElementById('parsed')!;
    const nats = document.getElementById('nats-output')!;

    // Update selected states on buttons
    document.querySelectorAll('.emoji-btn').forEach(btn => {
      const el = btn as HTMLElement;
      const isSelected = builder.emojis.some(e => e.emoji === el.dataset.emoji && e.category === el.dataset.category);
      el.classList.toggle('selected', isSelected);
    });

    if (builder.emojis.length === 0) {
      output.innerHTML = '<span class="placeholder">Click emojis below to start building...</span>';
      parsed.innerHTML = '<div class="parsed-empty">Your parsed entity will appear here</div>';
      nats.innerHTML = '<span class="placeholder">greenlight.{state}.{scale}.{domain}.{id}</span>';
      return;
    }

    // Display emoji string
    output.textContent = builder.emojis.map(e => e.emoji).join('');

    // Parsed output
    const fields: Record<string, string> = {};
    builder.emojis.forEach(e => {
      fields[e.category] = e.code;
    });

    parsed.innerHTML = Object.entries(fields).map(([key, value]) =>
      `<div class="parsed-row"><span class="parsed-key">${key}:</span><span class="parsed-value">${value}</span></div>`
    ).join('');

    // NATS subject
    const lifecycle = fields.lifecycle || '*';
    const scale = fields.scale || '*';
    const domain = fields.domain || '*';
    nats.innerHTML = `greenlight.<span style="color:var(--green)">${lifecycle}</span>.<span style="color:var(--green)">${scale}</span>.<span style="color:var(--green)">${domain}</span>.<span style="color:var(--gray)">{id}</span>`;
  }

  // Emoji button clicks
  document.getElementById('picker')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.emoji-btn') as HTMLElement | null;
    if (!btn) return;

    const emoji = btn.dataset.emoji!;
    const category = btn.dataset.category!;
    const code = btn.dataset.code!;

    // Replace same category or add new
    const existing = builder.emojis.findIndex(e => e.category === category);
    if (existing >= 0) {
      if (builder.emojis[existing].emoji === emoji) {
        builder.emojis.splice(existing, 1); // Toggle off
      } else {
        builder.emojis[existing] = { emoji, category, code }; // Replace
      }
    } else {
      builder.emojis.push({ emoji, category, code });
    }

    // Sort by conventional order
    const order = ['lifecycle', 'scale', 'domain', 'priority', 'owner', 'agent'];
    builder.emojis.sort((a, b) => order.indexOf(a.category) - order.indexOf(b.category));

    render();
  });

  // Clear button
  document.getElementById('clear-btn')!.addEventListener('click', () => {
    builder.emojis = [];
    render();
  });

  // Copy button
  document.getElementById('copy-btn')!.addEventListener('click', () => {
    const text = builder.emojis.map(e => e.emoji).join('');
    if (text) {
      navigator.clipboard.writeText(text);
      const btn = document.getElementById('copy-btn')!;
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
    }
  });

  // Preset examples
  document.querySelectorAll('.example-preset').forEach(preset => {
    preset.addEventListener('click', () => {
      const emojis = (preset as HTMLElement).dataset.emojis!;
      builder.emojis = [];

      // Segment the emoji string
      const segmenter = new Intl.Segmenter('en', { granularity: 'grapheme' });
      const segments = [...segmenter.segment(emojis)].map(s => s.segment);

      segments.forEach(emoji => {
        // Find matching button
        const btn = document.querySelector(`.emoji-btn[data-emoji="${emoji}"]`) as HTMLElement | null;
        if (btn) {
          builder.emojis.push({
            emoji,
            category: btn.dataset.category!,
            code: btn.dataset.code!,
          });
        }
      });

      render();
    });
  });

  render();
</script>
